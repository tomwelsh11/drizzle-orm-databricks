{
  "name": "drizzle-orm-adapter-databricks",
  "version": "0.1.0",
  "description": "Databricks SQL adapter for Drizzle ORM",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./migrator": {
      "types": "./dist/migrator.d.ts",
      "import": "./dist/migrator.js",
      "require": "./dist/migrator.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:types": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write ."
  },
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "databricks",
    "sql",
    "adapter",
    "orm"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "drizzle-orm": ">=0.36.0",
    "@databricks/sql": ">=1.8.0"
  },
  "devDependencies": {
    "@databricks/sql": "^1.8.0",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-orm": "^0.36.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
